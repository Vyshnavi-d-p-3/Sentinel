# Sentinel Backend — Production Environment
# Copy to .env and fill in all values before deploying.
# --- Runtime ---
ENVIRONMENT=production
# --- Database (use your Neon/Supabase connection string) ---
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/sentinel
DB_AUTO_CREATE_TABLES=false
# --- GitHub App (register at https://github.com/settings/apps) ---
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
# --- LLM API Keys ---
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...
LLM_MOCK_MODE=false
LLM_CALL_TIMEOUT_SEC=60
# --- Cost Guard ---
DAILY_TOKEN_BUDGET=100000
PER_PR_TOKEN_CAP=20000
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_WINDOW_SEC=300
# --- Retrieval (optional — falls back to diff-only without VoyageAI key) ---
VOYAGEAI_API_KEY=
EMBEDDING_MODEL=voyage-code-3
EMBEDDING_DIM=1024
# --- Observability (optional — Langfuse cloud free tier) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# --- CORS (set to your Vercel dashboard URL) ---
CORS_ORIGINS=["https://sentinel-dashboard.vercel.app"]
# --- Dashboard API protection ---
API_KEY=generate-a-64-char-random-string-here
# --- Rate Limits ---
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_WEBHOOK=60/minute
RATE_LIMIT_PREVIEW=10/minute
RATE_LIMIT_EVAL_TRIGGER=5/hour
# --- Eval (keep disabled in prod unless you explicitly want HTTP-triggered evals) ---
EVAL_TRIGGER_ENABLED=false
EVAL_TRIGGER_FORCE_MOCK=true
