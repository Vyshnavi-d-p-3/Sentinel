DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel
DB_AUTO_CREATE_TABLES=true
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_WEBHOOK_SECRET=
ANTHROPIC_API_KEY=s9383ab45-2b27-49e2-8079-d9533cbc1b7c
OPENAI_API_KEY=sk-...
# Set true for deterministic output without calling LLM APIs (CI / demos).
LLM_MOCK_MODE=false
LLM_CALL_TIMEOUT_SEC=60
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# --- Retrieval / embeddings (optional — falls back to diff-only without key) ---
VOYAGEAI_API_KEY=
EMBEDDING_MODEL=voyage-code-3
EMBEDDING_DIM=1024
# --- CORS (comma-separated or JSON array of allowed origins) ---
CORS_ORIGINS=["http://localhost:3000"]
# --- Dashboard API protection (mirror in NEXT_PUBLIC_API_KEY for the UI) ---
API_KEY=
# --- Rate limits ---
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_WEBHOOK=60/minute
RATE_LIMIT_PREVIEW=10/minute
RATE_LIMIT_EVAL_TRIGGER=5/hour
# --- Cost guard ---
DAILY_TOKEN_BUDGET=100000
PER_PR_TOKEN_CAP=20000
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_WINDOW_SEC=300
# --- Optional: POST /api/v1/eval/trigger runs eval/scripts/eval_runner.py ---
# Leave false in production unless you explicitly want operators to spawn evals via HTTP.
EVAL_TRIGGER_ENABLED=false
EVAL_TRIGGER_TIMEOUT_SEC=600
# Force mock LLM inside the subprocess so triggers cannot burn provider quota (recommended).
EVAL_TRIGGER_FORCE_MOCK=true
