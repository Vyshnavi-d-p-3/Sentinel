# ---------------------------------------------------------------------------
# Sentinel — example environment file.
# Copy to .env and fill in real values. Never commit the populated .env.
# ---------------------------------------------------------------------------

# Runtime mode: development | staging | production | test
ENVIRONMENT=development

# ---- Database -------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@db:5432/sentinel
DB_AUTO_CREATE_TABLES=true
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=sentinel

# ---- LLM gateway ----------------------------------------------------------
# Leave both empty + LLM_MOCK_MODE=true to run the deterministic stub model
# (great for local dev and CI). Set at least one in production.
LLM_MOCK_MODE=true
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEFAULT_MODEL=claude-sonnet-4-20250514
FALLBACK_MODEL=gpt-4o
LLM_CALL_TIMEOUT_SEC=60

# ---- Cost guard -----------------------------------------------------------
DAILY_TOKEN_BUDGET=100000
PER_PR_TOKEN_CAP=20000
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_WINDOW_SEC=300

# ---- Retrieval ------------------------------------------------------------
VOYAGEAI_API_KEY=
EMBEDDING_MODEL=voyage-code-3
EMBEDDING_DIM=1024
RETRIEVAL_TOP_K=5

# ---- GitHub App -----------------------------------------------------------
# Set GITHUB_WEBHOOK_SECRET to a high-entropy random string and configure the
# same value in your GitHub App settings.
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_WEBHOOK_SECRET=

# ---- Observability --------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
SENTINEL_LOG_FORMAT=json     # text | json
SENTINEL_LOG_LEVEL=INFO

# ---- Dashboard ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Security -------------------------------------------------------------
# Optional API key required on /api/v1/* endpoints. When empty, dashboard
# routes are open (fine for local dev). MUST be set in production.
API_KEY=
# JSON-encoded list of allowed dashboard origins.
CORS_ORIGINS=["http://localhost:3000"]
# Hard cap on incoming request body size (bytes).
MAX_REQUEST_BODY_BYTES=2097152
# Per-IP rate limits (slowapi syntax).
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_WEBHOOK=60/minute
RATE_LIMIT_PREVIEW=10/minute

# ---- Compose port mappings (optional overrides) ---------------------------
BACKEND_PORT=8000
DASHBOARD_PORT=3000
POSTGRES_PORT=5432
